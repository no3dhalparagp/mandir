generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  COMMITTEE_ADMIN
  ACCOUNTANT
  DATA_ENTRY_OPERATOR
  VIEWER
}

enum MemberDesignation {
  PRESIDENT
  VICE_PRESIDENT
  SECRETARY
  JOINT_SECRETARY
  TREASURER
  JOINT_TREASURER
  MEMBER
  VOLUNTEER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  RETIRED
}

enum DonationCategory {
  GENERAL
  PUJA
  FESTIVAL
  CONSTRUCTION
  ANNADAN
  SPECIAL
  SEWA
  TRUST_FUND
}

enum PaymentMode {
  CASH
  UPI
  CHEQUE
  NEFT
  RTGS
  DD
  IMPS
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
  PUJA_MATERIALS
  ELECTRICITY
  SALARY
  MAINTENANCE
  DECORATION
  FOOD_PRASAD
  CONSTRUCTION
  PRINTING
  TRANSPORT
  MISC
}

enum AccountType {
  SAVINGS
  CURRENT
  CASH_IN_HAND
  FIXED_DEPOSIT
}

enum CollectionStatus {
  COLLECTED // Member has collected the amount
  DEPOSITED // Member has submitted to accountant
  VERIFIED // Accountant has verified the amount
  DISCREPANT // Amount mismatch found
}

enum LedgerTransactionType {
  INCOME
  EXPENSE
  TRANSFER_IN
  TRANSFER_OUT
  MEMBER_DEPOSIT
  OPENING_BALANCE
  ADJUSTMENT
}

enum ReconciliationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum COAAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum EntryType {
  DEBIT
  CREDIT
}

enum ChequeNature {
  RECEIVED
  ISSUED
}

enum ChequeStatus {
  PENDING
  CLEARED
  BOUNCED
  CANCELLED
}

enum AssetStatus {
  ACTIVE
  UNDER_MAINTENANCE
  DISPOSED
}

enum DepreciationMethod {
  STRAIGHT_LINE
  WRITTEN_DOWN_VALUE
}

enum ChequeLeafStatus {
  UNUSED
  ISSUED
  CANCELLED
}

enum BookClosureType {
  MONTH
  YEAR
}

// ─── Core User ────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Security fields
  lastLoginAt      DateTime?
  lastLoginIp      String?
  lastLoginDevice  String?
  loginAttempts    Int       @default(0)
  lockedUntil      DateTime?
  passwordChangedAt DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?

  approvedExpenses       Expense[]               @relation("ApprovedExpenses")
  verifiedCollections    MemberCollection[]      @relation("VerifiedCollections")
  reconciliations        BankReconciliation[]    @relation("ReconciledBy")
  member                 Member?
  accountingTransactions AccountingTransaction[]
  bookClosures           BookClosure[]           @relation("BookClosedBy")
  auditLogs              AuditLog[]
  loginHistories         LoginHistory[]
  activeSessions         ActiveSession[]
}

// ─── Chart of Accounts ─────────────────────────────────────────────────────────

model ChartOfAccount {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  code        String           @unique
  name        String
  type        COAAccountType
  parentId    String?          @db.ObjectId
  parent      ChartOfAccount?  @relation("ParentAccount", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    ChartOfAccount[] @relation("ParentAccount")
  isActive    Boolean          @default(true)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  bankAccount    BankAccount?
  journalEntries JournalEntry[]
}

// ─── Double-Entry Accounting Transaction ───────────────────────────────────────

model AccountingTransaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  transactionNo String   @unique
  date          DateTime @default(now())
  description   String
  referenceType String?
  referenceId   String?
  status        String   @default("POSTED")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById String?        @db.ObjectId
  createdBy   User?          @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entries     JournalEntry[]
}

model JournalEntry {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  transactionId String                @db.ObjectId
  transaction   AccountingTransaction @relation(fields: [transactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  accountId     String                @db.ObjectId
  account       ChartOfAccount        @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  entryType     EntryType
  amount        Float
  description   String?
  createdAt     DateTime              @default(now())
}

// ─── Bank & Cash Accounts ─────────────────────────────────────────────────────

model BankAccount {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  name           String // e.g. "SBI Main A/C", "Cash in Hand"
  accountNumber  String?     @unique
  bankName       String?
  branchName     String?
  ifscCode       String?
  accountType    AccountType @default(SAVINGS)
  openingBalance Float       @default(0)
  isActive       Boolean     @default(true)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  coaId String?         @unique @db.ObjectId
  coa   ChartOfAccount? @relation(fields: [coaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  ledgerEntries   LedgerEntry[]
  donations       Donation[]
  expenses        Expense[]
  transfersFrom   FundTransfer[]       @relation("TransferFrom")
  transfersTo     FundTransfer[]       @relation("TransferTo")
  collections     MemberCollection[]
  reconciliations BankReconciliation[]
  chequeEntries   ChequeRegister[]
  assets          AssetRegister[]
  chequeBooks     ChequeBook[]
  chequeLeaves    ChequeBookLeaf[]
  bankPassbooks   BankPassbook[]
  depositVerifications DepositVerification[]
}

// ─── Fund Transfer between accounts ──────────────────────────────────────────

model FundTransfer {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  fromAccountId String   @db.ObjectId
  toAccountId   String   @db.ObjectId
  amount        Float
  transferDate  DateTime @default(now())
  referenceNo   String?
  notes         String?
  createdAt     DateTime @default(now())

  fromAccount BankAccount @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toAccount   BankAccount @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Committee Members ────────────────────────────────────────────────────────

model Member {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  memberId    String            @unique // e.g. MEM-001
  name        String
  designation MemberDesignation @default(MEMBER)
  mobile      String?
  email       String?
  address     String?
  photoUrl    String?
  joiningDate DateTime          @default(now())
  status      MemberStatus      @default(ACTIVE)
  canCollect  Boolean           @default(false) // Whether this member is authorized to collect funds
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId String? @unique @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  collections MemberCollection[]
  donations   Donation[]         @relation("CollectedByMember")
  memberAccount MemberAccount?
  depositVerifications DepositVerification[]
}

// ─── Donations ────────────────────────────────────────────────────────────────

model Donation {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  donorName      String
  mobileNumber   String?
  address        String?
  category       DonationCategory @default(GENERAL)
  amount         Float
  paymentMode    PaymentMode      @default(CASH)
  transactionId  String? // UPI/NEFT/RTGS ref number
  chequeNumber   String?
  chequeDate     DateTime?
  bankNameCheque String? // Bank name on cheque
  receiptNo      String           @unique
  date           DateTime         @default(now())
  notes          String?

  // Which account this donation was credited to
  accountId String?      @db.ObjectId
  account   BankAccount? @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Collected by which member (field collection)
  collectedByMemberId String? @db.ObjectId
  collectedByMember   Member? @relation("CollectedByMember", fields: [collectedByMemberId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipt          Receipt?
  memberCollection MemberCollection?
  chequeEntry      ChequeRegister?
}

// ─── Member Collections ───────────────────────────────────────────────────────

model MemberCollection {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String           @db.ObjectId
  donationId      String           @unique @db.ObjectId
  collectedAmount Float
  collectedDate   DateTime         @default(now())
  status          CollectionStatus @default(COLLECTED)

  // Deposit details
  depositedToAccountId String?   @db.ObjectId
  depositedDate        DateTime?
  depositSlipNo        String?

  // Verification
  verifiedById    String?   @db.ObjectId
  verifiedAt      DateTime?
  discrepancyNote String?
  verifiedAmount  Float?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member             Member       @relation(fields: [memberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  donation           Donation     @relation(fields: [donationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  depositedToAccount BankAccount? @relation(fields: [depositedToAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verifiedBy         User?        @relation("VerifiedCollections", fields: [verifiedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Expenses ─────────────────────────────────────────────────────────────────

model Expense {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  category      ExpenseCategory @default(MISC)
  amount        Float
  vendorName    String?
  vendorMobile  String?
  paymentMode   PaymentMode     @default(CASH)
  chequeNumber  String?
  chequeDate    DateTime?
  transactionId String?
  billNumber    String?
  billDate      DateTime?
  expenseDate   DateTime        @default(now())
  status        ExpenseStatus   @default(PENDING)
  attachmentUrl String?
  notes         String?

  // Paid from which account
  accountId String?      @db.ObjectId
  account   BankAccount? @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  approvedById String?   @db.ObjectId
  approvedAt   DateTime?
  approvedBy   User?     @relation("ApprovedExpenses", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chequeEntry ChequeRegister?
  chequeLeafId String?         @unique @db.ObjectId
  chequeLeaf   ChequeBookLeaf? @relation(fields: [chequeLeafId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Cheque Register ───────────────────────────────────────────────────────────

model ChequeRegister {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  chequeNumber  String
  chequeDate    DateTime
  bankName      String?
  amount        Float
  partyName     String?
  nature        ChequeNature
  status        ChequeStatus @default(PENDING)
  clearedDate   DateTime?
  bouncedReason String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accountId String?      @db.ObjectId
  account   BankAccount? @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  donationId String?    @unique @db.ObjectId
  donation   Donation?  @relation(fields: [donationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  expenseId String?   @unique @db.ObjectId
  expense   Expense?  @relation(fields: [expenseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  chequeLeafId String?         @unique @db.ObjectId
  chequeLeaf   ChequeBookLeaf? @relation(fields: [chequeLeafId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ChequeBook {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bookNo      String
  startNumber String
  endNumber   String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accountId String      @db.ObjectId
  account   BankAccount @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  leaves ChequeBookLeaf[]
}

model ChequeBookLeaf {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  chequeNumber   String
  status         ChequeLeafStatus @default(UNUSED)
  issuedAt       DateTime?
  cancelledAt    DateTime?
  cancelledReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  chequeBookId String    @db.ObjectId
  chequeBook   ChequeBook @relation(fields: [chequeBookId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  accountId String      @db.ObjectId
  account   BankAccount @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  expense      Expense?
  chequeEntry  ChequeRegister?

  @@unique([accountId, chequeNumber])
}

// ─── Asset Register ────────────────────────────────────────────────────────────

model AssetRegister {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  assetCode          String             @unique
  name               String
  category           String
  purchaseDate       DateTime
  purchaseValue      Float
  residualValue      Float              @default(0)
  usefulLifeYears    Int?
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  location           String?
  custodian          String?
  vendorName         String?
  invoiceNumber      String?
  status             AssetStatus        @default(ACTIVE)
  currentBookValue   Float?
  disposalDate       DateTime?
  disposalValue      Float?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  purchaseAccountId String?      @db.ObjectId
  purchaseAccount   BankAccount? @relation(fields: [purchaseAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  depreciationEntries AssetDepreciationEntry[]
}

model AssetDepreciationEntry {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId       String   @db.ObjectId
  periodStart   DateTime
  periodEnd     DateTime
  amount        Float
  postedDate    DateTime @default(now())
  journalRef    String?
  notes         String?
  createdAt     DateTime @default(now())

  asset AssetRegister @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  eventType      String    @default("PUJA") // PUJA, FESTIVAL, MEETING, OTHER
  date           DateTime
  endDate        DateTime?
  budget         Float?
  actualExpense  Float?
  organizer      String?
  sponsorDetails String?
  notes          String?
  status         String    @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Ledger ───────────────────────────────────────────────────────────────────

model LedgerEntry {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime              @default(now())
  type          LedgerTransactionType @default(INCOME)
  amount        Float
  description   String
  referenceType String? // "DONATION", "EXPENSE", "TRANSFER", "MEMBER_DEPOSIT"
  referenceId   String?

  accountId String      @db.ObjectId
  account   BankAccount @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  runningBalance Float?
  isReconciled   Boolean   @default(false)
  reconciledAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Bank Reconciliation ──────────────────────────────────────────────────────

model BankReconciliation {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  accountId          String               @db.ObjectId
  statementFromDate  DateTime
  statementToDate    DateTime
  openingBalanceBook Float
  closingBalanceBook Float
  openingBalanceBank Float
  closingBalanceBank Float
  difference         Float
  status             ReconciliationStatus @default(DRAFT)
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  reconciledById String?   @db.ObjectId
  reconciledAt   DateTime?

  account      BankAccount              @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reconciledBy User?                    @relation("ReconciledBy", fields: [reconciledById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items        BankReconciliationItem[]
}

model BankReconciliationItem {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  reconciliationId     String    @db.ObjectId
  ledgerEntryId        String?   @db.ObjectId
  statementDate        DateTime
  statementAmount      Float
  statementDescription String?
  isMatched            Boolean   @default(false)
  matchedAt            DateTime?

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Receipt ──────────────────────────────────────────────────────────────────

model Receipt {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  receiptNo   String   @unique
  donationId  String   @unique @db.ObjectId
  donation    Donation @relation(fields: [donationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pdfUrl      String?
  generatedAt DateTime @default(now())
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  entity    String
  entityId  String?
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model BookClosure {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  closureType BookClosureType
  label       String
  periodStart DateTime
  periodEnd   DateTime
  notes       String?
  closedAt    DateTime        @default(now())

  closedById String? @db.ObjectId
  closedBy   User?   @relation("BookClosedBy", fields: [closedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([closureType, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
}

// ─── Login History ────────────────────────────────────────────────────────────

model LoginHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String
  device    String?
  userAgent String?
  success   Boolean  @default(true)
  reason    String?  // For failed attempts
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Active Session ───────────────────────────────────────────────────────────

model ActiveSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String
  device    String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  lastActivityAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── User Invite ──────────────────────────────────────────────────────────────

model UserInvite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  role      Role     @default(VIEWER)
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ─── Member Account & Passbook ────────────────────────────────────────────────

model MemberAccount {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  memberId          String   @unique @db.ObjectId
  member            Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  openingBalance    Float    @default(0)
  currentBalance    Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  passbooks         Passbook[]

  @@index([memberId])
}

model Passbook {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  date              DateTime
  description       String
  referenceType     String?  // "DONATION", "EXPENSE", "TRANSFER", "MEMBER_DEPOSIT"
  referenceId       String?
  debit             Float    @default(0)  // Money going out
  credit            Float    @default(0) // Money coming in
  balance           Float
  createdAt         DateTime @default(now())

  memberAccountId   String   @db.ObjectId
  memberAccount     MemberAccount @relation(fields: [memberAccountId], references: [id], onDelete: Cascade)

  @@index([memberAccountId])
  @@index([date])
  @@index([createdAt])
}

// ─── Bank Passbook ────────────────────────────────────────────────────────────

model BankPassbook {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  date              DateTime
  description       String
  referenceType     String   // "DONATION", "DEPOSIT", "WITHDRAWAL", "TRANSFER_IN", "TRANSFER_OUT", "EXPENSE"
  referenceId       String?
  debit             Float    @default(0)  // Money going out
  credit            Float    @default(0) // Money coming in
  balance           Float
  isVerified        Boolean  @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?  @db.ObjectId // User ID
  createdAt         DateTime @default(now())

  bankAccountId     String   @db.ObjectId
  bankAccount       BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([date])
  @@index([isVerified])
  @@index([createdAt])
}

// ─── Deposit Verification ─────────────────────────────────────────────────────

model DepositVerification {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  depositAmount     Float
  depositDate       DateTime
  status            String   @default("PENDING") // "PENDING", "VERIFIED", "REJECTED", "RECONCILED"
  
  collectedByName   String?  // Member name who collected
  collectedMemberId String?  @db.ObjectId
  member            Member?  @relation(fields: [collectedMemberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  bankAccountId     String   @db.ObjectId
  bankAccount       BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  
  receiptNo         String?
  notes             String?
  
  verifiedAt        DateTime?
  verifiedBy        String?  @db.ObjectId // User ID
  rejectionReason   String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([bankAccountId])
  @@index([status])
  @@index([depositDate])
  @@index([collectedMemberId])
}

enum DepositStatus {
  PENDING
  VERIFIED
  REJECTED
  RECONCILED
}
